# NeuralPath — Environment Variables
# Copy this file to .env and fill in your values.
# VITE_* variables are exposed to the browser bundle.

# ─── Backend ──────────────────────────────────────────────────────────────────
# Google Apps Script Web App deployment URL
# If not set, the app falls back to the bundled GAS endpoint in config.js
VITE_BACKEND_URL=https://script.google.com/macros/s/<YOUR_DEPLOYMENT_ID>/exec

# ─── Payments (Razorpay) ──────────────────────────────────────────────────────
# Your Razorpay Key ID (starts with rzp_live_ or rzp_test_)
VITE_RAZORPAY_KEY=rzp_test_xxxxxxxxxxxx

# ─── Social / Community ───────────────────────────────────────────────────────
VITE_WHATSAPP_LINK=https://wa.me/91XXXXXXXXXX
VITE_LINKEDIN_PAGE=https://linkedin.com/company/neuralpath
VITE_YOUTUBE_CHANNEL=https://youtube.com/@neuralpath
